  "poets": [
    {
      "id": "poet-1",
      "name": "تراحيب السويلم",
      "wasm": "wasm-1",
      "bio": "تراحيب بن سويلم العتيبي، شاعر نبطي سعودي.",
      "poems": [
        {
          "id": "poet-1-poem-1",
          "title": "برج خليفة",
          "meter": "",
          "date": "2011",
          "source": "موقع الشعر",
          "verses": [
            { "sadr": "لو الشعوب إلى الثريا تسابق", "ajz": "ما أحدٍ سبق بالفعل شعب الأمارات" },
            { "sadr": "ودليلنا ميّة وستين طابق", "ajz": "اللي بنوها فوق كل العمارات" },
            { "sadr": "برجٍ بنوه، بطيب الأفعال عابق", "ajz": "من آجل الفخر ماهو من أجل الإيجارات" },
            { "sadr": "شعب وحكومه للمعالي سوابق", "ajz": "بنّو عماراتٍ وبنّو منارات" },
            { "sadr": "فوق السحاب أعمالهم سبق سابق", "ajz": "وقمّة خليفه فوق كل العبارات" }
          ]
        },
        {
          "id": "poet-1-poem-2",
          "title": "شكراً وهي كافيه",
          "meter": "",
          "date": "2011",
          "source": "موقع الشعر",
          "verses": [
            { "sadr": "ياكاتب أبياتي وفيت", "ajz": "تسلم يمين وافيه" },
            { "sadr": "من غير ما أنخاك إنتخيت", "ajz": "ياكامل الآوصافيه" },
            { "sadr": "وكتبت لي تسعين بيت", "ajz": "مع مثلها بالقافيه" },
            { "sadr": "مشكور يالغالي وليت", "ajz": "دايم حياتك صافيه" },
            { "sadr": "عساك طيب ماحييت", "ajz": "ترفل بثوب العافيه" },
            { "sadr": "فالمملكه أو فالكويت", "ajz": "ماأرضى عليك خلافيه" },
            { "sadr": "دامك على الواضح مشيت", "ajz": "مابه نوايا خافيه" },
            { "sadr": "أكيد يوم إني هقيت", "ajz": "إن القلوب نظافيه" },
            { "sadr": "أنا لماتكتب قريت", "ajz": "وشفت آجوبتكم شافيه" },
            { "sadr": "ماينهدم بني بنيت", "ajz": "وشكراً ولاهي كافيه" }
          ]
        },
        {
          "id": "poet-1-poem-3",
          "title": "ردّ على ابن شامان",
          "meter": "",
          "date": "2008",
          "source": "موقع الشعر",
          "verses": [
            { "sadr": "حي الكتاب اللي من الشمّري جيب", "ajz": "أقولها بالصدق ماني بكذاب" },
            { "sadr": "يا مرحبا عد النجوم المراقيب", "ajz": "ترحيب مشتاقٍ ليا شاف الأحباب" },
            { "sadr": "بكتاب ابن شامان رجل المواجيب", "ajz": "فيه الجواهر بين صايغ وحساب" },
            { "sadr": "بنيت له بأقصى ضميري دواليب", "ajz": "هذا الرصيد اللي كنزته وراء الباب" },
            { "sadr": "من شأن ثامر يرخصن المطاليب", "ajz": "خوينا الطيب له الحق غصاب" },
            { "sadr": "خوينا ننصاب مثله ليا صيب", "ajz": "نمرض معه ونطيب مثله ليا طاب" },
            { "sadr": "يا عل ما يفتق على مثله الجيب", "ajz": "والله يجيره من صواديف الأسباب" }
          ]
        },
        {
          "id": "poet-1-poem-4",
          "title": "عرضت لي وأنا عابر سبيل",
          "meter": "",
          "date": "2008",
          "source": "موقع الشعر",
          "verses": [
            { "sadr": "عرضت لي وأنا عابر سبيل", "ajz": "والغريب إنّها من حارتي" },
            { "sadr": "النظر يم جاري مايخيل", "ajz": "ونظرتي ماتلد لجارتي" },
            { "sadr": "ما ألتفت للقصير وللطويل", "ajz": "لو بلمحه ورى نظارتي" },
            { "sadr": "لو دعتني ليا غاب الخليل", "ajz": "عزة النفس هي تجارتي" },
            { "sadr": "يوم صارت التيل حيل", "ajz": "صد عنها نحر سيارتي" },
            { "sadr": "رحت عنها على وارد جميل", "ajz": "لو بكت ماتشوف زيارتي" },
            { "sadr": "فوق جيبٍ معاليقه تشيل", "ajz": "مع دروب الظما مطارتي" },
            { "sadr": "ذللتني وانا ماني ذليل", "ajz": "ياعسى صدتي كفارتي" },
            { "sadr": "ازبن الله مااجي بيت البخيل", "ajz": "عند بيت الكريم خطارتي" },
            { "sadr": "حالفٍ انّي ماأموج عن الدليل", "ajz": "لو شكت عبر بث الآرتي" },
            { "sadr": "وبندقي عن هدفها ماتميل", "ajz": "لو على البعد تطرح شارتي" },
            { "sadr": "واحمد الله شرابي سلسبيل", "ajz": "واعزف لحني على قيثارتي" }
          ]
        },
        {
          "id": "poet-1-poem-5",
          "title": "يامرحبا عد وبلٍ هل هملوله",
          "meter": "",
          "date": "2008",
          "source": "موقع الشعر",
          "verses": [
            { "sadr": "يامرحبا عد وبلٍ هل هملوله", "ajz": "من مزنةٍ هلّت الماء من صنابرها" },
            { "sadr": "والف هلا بالبريد وحي مرسوله", "ajz": "اللي يجيب الرسايل من مصادرها" },
            { "sadr": "أبيات مثل الجواهر جات محموله", "ajz": "مجلة المختلف تحمل بشايرها" },
            { "sadr": "رسالةٍ من عيون الشعر معقوله", "ajz": "شكراً لمن قالها واشكر محررها" },
            { "sadr": "من شاعرٍ فالمحافل يكسب الجوله", "ajz": "في كل ميدان مايخشى مخاطرها" },
            { "sadr": "دايم سيوفه على الشعار مسلوله", "ajz": "وعند اللقا ينجلي عنها توترها" },
            { "sadr": "له قصةٍ ثابته ماهيب منقوله", "ajz": "عندي خبر كل ماضيها وحاضرها" },
            { "sadr": "السر بين الكفيل وبين مكفوله", "ajz": "الحر يفهم وانا ماني بناشرها" },
            { "sadr": "مابين مر الزمان وحلو معسوله", "ajz": "ماهمها غير وصلك وانت هاجرها" },
            { "sadr": "ازبن هل الحق واخذ الحق بدلوله", "ajz": "سوات زبنة رشيد ان كان تذكرها" },
            { "sadr": "ماضاع حقٍ وراه رجال مسؤوله", "ajz": "من خلقة الناس مسلمها وكافرها" },
            { "sadr": "بيوت الاجواد بالقانون مدخوله", "ajz": "وبيوت الانذال ودّك من يدمرها" }
          ]
        },
        {
          "id": "poet-1-poem-6",
          "title": "لاتغرك يافتى دنيا الورى",
          "meter": "",
          "date": "2008",
          "source": "موقع الشعر",
          "verses": [
            { "sadr": "لاتغرك يافتى دنيا الورى", "ajz": "لوتدوم لحى مادامت سنين" },
            { "sadr": "قم بدينك وانذر الى ما درى", "ajz": "واعبد الله لين ياتيك اليقين" },
            { "sadr": "الهوى والنفس بالسؤ أو مرى", "ajz": "والأمل غدار وابليس اللعين" },
            { "sadr": "لو وصلت النجم ترجع للثرى", "ajz": "كل ماسويت بالدنيا يبين" },
            { "sadr": "ساعة فيها القبور اتبعثرى", "ajz": "وانت يا مغرور بأعمالك رهين" },
            { "sadr": "يا خذ أقوالك نكير ومنكرى", "ajz": "من ملفك طلعوا كل الخزين" },
            { "sadr": "آه من عين سرى عنها الكرى", "ajz": "ما تنام العين والخافق حزين" },
            { "sadr": "دامهن بالهم والسهر اخشرى", "ajz": "من صبر يجزى ثواب الصابرين" },
            { "sadr": "من كريم نزله بام القرى", "ajz": "في بلد مكه على الرجل الأمين" },
            { "sadr": "يوم الجمع الخلق كله بالعرى", "ajz": "أطلبك تجعل كتابي باليمين" },
            { "sadr": "حطلي دون اللهب ظل وذرى", "ajz": "من لجى بحمالك بحصن حصين" }
          ]
        },
        {
          "id": "poet-1-poem-7",
          "title": "يا ولد من يوم عيوا بالاجازه",
          "meter": "",
          "date": "2008",
          "source": "موقع الشعر",
          "verses": [
            { "sadr": "يا ولد من يوم عيوا بالاجازه", "ajz": "حضروا كشف الغياب وسجلوني" },
            { "sadr": "لي وليفٍ بين شقراء والمحازه", "ajz": "عهدنا به قبل تفريق الضعوني" },
            { "sadr": "وقائد المظهور فنه وامتيازه", "ajz": "كل برقٍ لاح صوبه ينجعوني" },
            { "sadr": "راكب اللي كن ضربه مع جرازه", "ajz": "ضرب وبل الصيف من غر المزوني" },
            { "sadr": "طالبك يا سعود مسح لي قزازه", "ajz": "والأديتر غلقه من ماء عيوني" },
            { "sadr": "واترك الباقي عليه مع جهازه", "ajz": "عطني المفتاح علك ماتهوني" },
            { "sadr": "لو تعرض له وعر والا غرازه", "ajz": "ما رحمت الجمس والكاين يكوني" },
            { "sadr": "دون هاك الزين ما للجمس عازه", "ajz": "وان طفا من دون خلي نزلوني" },
            { "sadr": "واحفروا قبري وحطوا له ركازه", "ajz": "وأقرؤوا الدنيا سلامي وادفنوني" },
            { "sadr": "وادعوا المعبود يغفر للجنازه", "ajz": "يرحم الميت وللحيين عوني" }
          ]
        }
      ]
    },
    {
      "id": "poet-2",
      "name": "ضيف الله بن سويلم",
      "wasm": "wasm-2",
      "bio": "نص تعريفي تجريبي عن الشاعر الثاني.",
      "poems": [
        {
          "id": "poet-2-poem-1",
          "title": "نجم الصباح (نموذج)",
          "meter": "",
          "date": "",
          "source": "نموذج تجريبي",
          "verses": [
            {
              "sadr": "طلع نجم الصباح وضحكت الدنيا له",
              "ajz": "وغنّت الطير فوق الروض من فرحتها"
            },
            {
              "sadr": "وكل قلب تعب من زود ما حمّله",
              "ajz": "لقى في صوت الهديل بعض راحتها"
            },
            {
              "sadr": "يا ليت قلبي يصير مثل نجم الضحى",
              "ajz": "يطلع ويصفي ويهدي الكل من نورها"
            }
          ]
        },
        {
          "id": "poet-2-poem-2",
          "title": "خوي العمر (نموذج)",
          "meter": "",
          "date": "",
          "source": "نموذج تجريبي",
          "verses": [
            {
              "sadr": "يا خوي يا اللي وقفت معاي وقت الشدة",
              "ajz": "ما ينكتب لك بالكلام ولا يوصف"
            }
          ]
        }
      ]
    },
    {
      "id": "poet-3",
      "name": "محيل بن سويلم",
      "wasm": "wasm-3",
      "bio": "نص تعريفي تجريبي عن الشاعر الثالث.",
      "poems": [
        {
          "id": "poet-3-poem-1",
          "title": "درب الأصايل (نموذج)",
          "meter": "",
          "date": "",
          "source": "نموذج تجريبي",
          "verses": [
            {
              "sadr": "درب الأصايل طويل وما يهون على",
              "ajz": "إلا على من قلبه بالصبر متعلّق"
            },
            {
              "sadr": "والخطوة الأولى تجيك وما تجيك على",
              "ajz": "إلا إذا نيتك صافية ما تخلّق"
            }
          ]
        },
        {
          "id": "poet-3-poem-2",
          "title": "وصية أب (نموذج)",
          "meter": "",
          "date": "",
          "source": "نموذج تجريبي",
          "verses": [
            {
              "sadr": "قال الكبير وصيته يوم الفراق",
              "ajz": "خذها وصايا من قلب يدعي لكم"
            },
            {
              "sadr": "كونوا على الخير إخوان وعلى وفاق",
              "ajz": "والله يحفظكم ويجمعكم على كلمة"
            }
          ]
        }
      ]
    }
  ]
}

