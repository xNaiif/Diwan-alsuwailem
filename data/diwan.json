            {
              "sadr": "في صف من فعله يزيل اللوايم",
              "ajz": "أمثال ابو تركي وريس جهاما"
            },
            {
              "sadr": "عند العظيم تهون كل العظايم",
              "ajz": "وعند الصغير تصير مثل الحلاما"
            },
            {
              "sadr": "ياعلي كم وكم وافي خصايم",
              "ajz": "اللي تعلو فوق عال السناما"
            },
            {
              "sadr": "ابا أبتعد عن من يقول الظلايم",
              "ajz": "من يظلم المسلم غشاه الملاما"
            },
            {
              "sadr": "اللي يسبون النشاما هلايم",
              "ajz": "وسب الهلايم ما يضر النشاما"
            },
            {
              "sadr": "سود الوجيه مروجين النمايم",
              "ajz": "يأخذ من أمثاله ويعطي كلاما"
            },
            {
              "sadr": "حطوا لحوم الناس مثل الولايم",
