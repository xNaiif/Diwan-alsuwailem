    {
      "id": "ext-1",
      "name": "حبيب العازمي",
      "poems": [
        {
          "id": "ext-1-poem-1",
          "title": "ردوا سلامي لابوناصر وقولو له",
          "role": "بدع",
          "source": "موقع الشعر",
          "verses": [
            {
              "sadr": "ردوا سلامي لابوناصر وقولو له",
              "ajz": "يقرا الرساله من اولها ليا آخرها"
            },
            {
              "sadr": "ارسالةٍ مع وجيه الخير مرسوله",
              "ajz": "والمسك والعود الازرق في مكاسرها"
            },
            {
              "sadr": "وجّهتها من ضميرٍ ضايقٍ جوله",
              "ajz": "للشاعر اللي معانيها يقدّرها"
            },
            {
              "sadr": "شاعر ويفتل وينقض كل مفتوله",
              "ajz": "وإرسالتي ماحدٍ غيره يفسرها"
            },
            {
              "sadr": "ان كان ماحلها ماهيب محلوله",
              "ajz": "ابا اكتم السر لين الله ييسّرها"
            },
            {
              "sadr": "لي قصةٍ واضحه في حكم مجهوله",
              "ajz": "قصة غرامٍ تعبّر عن مشاعرها"
            },
            {
              "sadr": "من شانها القلب والافكار مشغوله",
              "ajz": "والنار وسط الحشا شبّت سعايرها"
            },
            {
              "sadr": "كنّي بعزله وكن الناس معزوله",
              "ajz": "واستغرب الناس ماكني بخابرها"
            },
            {
              "sadr": "واصول لو كان لاصوله ولاجوله",
              "ajz": "احاول احل دعوايه وادبرها"
            },
            {
              "sadr": "واصاحبي دونه البيبان مقفوله",
              "ajz": "ماياصله كود من يقدر يكسرها"
            },
            {
              "sadr": "العام حوله وحول العام جا حوله",
              "ajz": "وانا عنه سجتي بالرجل قاصرها"
            },
            {
              "sadr": "ماهوب ودي لكن السلم وأوصوله",
              "ajz": "يردني والعرب كثرت مشاورها"
            },
            {
              "sadr": "خلي ورا دولةٍ من دونها دوله",
              "ajz": "دوله ودوله مجهّزةٍ عساكرها"
            },
            {
              "sadr": "حتى خطوط الهواتف عنه مفصوله",
              "ajz": "نقطة قلم وسط غبّه من يدورها"
            },
            {
              "sadr": "حاولت لين ان جهدي ضاع مفعوله",
              "ajz": "غيّر عرب والطبيعه ماتغيرها"
            },
            {
              "sadr": "والحبل لو يستوي عرضه على طوله",
              "ajz": "كلٍّ يطّول حباله مايقصرها"
            },
            {
              "sadr": "ودروب ماتندهل ودروب مدهوله",
              "ajz": "ولا كل من يعبر الاقطار يعبرها"
            },
            {
              "sadr": "هذه موجز وكثر الهرج وشهوله",
              "ajz": "الله يعلم بباطنها وظاهرها"
            },
            {
              "sadr": "يعلم على كل ماننويه ونقوله",
              "ajz": "وفي حكمه النفس ينهاها ويامرها"
            },
            {
              "sadr": "واختامها عد نوٍّ هلّت ثعوله",
              "ajz": "بالمسك والورد والكادي نعطّرها"
            }
          ]
        }
      ]
    },
    {
      "id": "ext-2",
      "name": "ناصر بن تراحيب العازمي العتيبي",
      "poems": [
        {
          "id": "ext-2-poem-1",
          "title": "ياراكب اللي بالسماء كنها الطير",
          "role": "بدع",
          "source": "موقع الشعر",
          "verses": [
            {
              "sadr": "ياراكب اللي بالسماء كنها الطير",
              "ajz": "تسبق سناء البرق الذي يسبق الصوت"
            },
            {
              "sadr": "منصاك قرمٍ من رجالٍ مناعير",
              "ajz": "قرمٍ من الشيمات والعز منحوت"
            },
            {
              "sadr": "مهما كتبنا عن فعوله تقارير",
              "ajz": "صعبٍ علينا حصر الافعال فبيوت"
            },
            {
              "sadr": "ضرغام من صغره يقود الطوابير",
              "ajz": "نال المراجل وإلتهمها كما الحوت"
            },
            {
              "sadr": "في مجلسٍ تاجه وجيهٍ مسافير",
              "ajz": "عاصي على الأشرار مافيه سربوت"
            },
            {
              "sadr": "زبن النشاما من ضيوف ومسايير",
              "ajz": "مدهل هل النخوات لاشك مثبوت"
            },
            {
              "sadr": "وإسلم وبلغ له سلامي على خير",
              "ajz": "سلامٍ أغلى من قناطير ياقوت"
            },
            {
              "sadr": "وألذ واحلى من حليب المغاتير",
              "ajz": "ذوقه لذيذ وشافي وكافي وقوت"
            },
            {
              "sadr": "والقلب ملك بصك بيض الغنادير",
              "ajz": "والجسم صار عظام والحال مسحوت"
            },
            {
              "sadr": "منهي تهون إلها جميع المخاسير",
              "ajz": "منهي فداها من سكن وسط بيروت"
            }
          ]
        }
      ]
    },
    {
      "id": "ext-3",
      "name": "حبيب بن دغيم العازمي",
      "poems": [
        {
          "id": "ext-3-poem-1",
          "title": "ضيف الله اخترت القوافي والطواريق الجدد",
          "role": "بدع",
          "source": "موقع الشعر",
          "verses": [
            {
              "sadr": "ضيف الله اخترت القوافي والطواريق الجدد",
              "ajz": "اللي سريعه فالندب واللي بطيه فالردود"
            },
            {
              "sadr": "اسرع ندب من صنعة البلجيك سمحات الخدد",
              "ajz": "واثقل من احمول البواخر بالكناتر والشدود"
            },
            {
              "sadr": "يقراهن الشاعر ويحفظهن خياله بالعدد",
              "ajz": "حرفٍ بحرف وكل حرف الياورد حرف امعدود"
            },
            {
              "sadr": "الساس ساس المعرفه والبني اخير امن الهدد",
              "ajz": "ابني على المبني بني وابني من البني امهدود"
            },
            {
              "sadr": "مثل الجسور اللي مصممةٍ على وزن القدد",
              "ajz": "او مثل طيٍ بالحجر تطوابه اعماق العدود"
            },
            {
              "sadr": "ما اطلب من الناس المدد اطلب من الرب المدد",
              "ajz": "مد الكريم اخير وابرك من جزيلات المدود"
            },
            {
              "sadr": "والياعطا يعطي ولايرجي من الناس الردد",
              "ajz": "جزلٍ ثمين الفضل والعرفان للرب الودود"
            },
            {
              "sadr": "عسا عيون الحاسدين اللي تناظر باللدد",
              "ajz": "حتى يعود شوفها بين المدامع والخدود"
            },
            {
              "sadr": "عز الله انا ماتوايقنا على سد السدد",
              "ajz": "تبقى السراير بالضماير لو يبيحن السدود"
            },
            {
              "sadr": "كنا منول ننطق الغده على جمع الغدد",
              "ajz": "ما تتفق مع قولة افلان اصبح اليوم امغدود"
            },
            {
              "sadr": "وكنا نقول افلان وابن افلان فاللازم سدد",
              "ajz": "واثر ما كل اللي بدا في لازمٍ يحسب سدود"
            },
            {
              "sadr": "لا هنت ياعون الرفيق الند الامثل للندد",
              "ajz": "رمز الكرم منصى الرجال وضد لخصم اللدود"
            },
            {
              "sadr": "يا عزوتي فالمواقف اللي فيه ضدا من الضدد",
              "ajz": "يتاج راسي ياحزامي من على عهد الجدود"
            },
            {
              "sadr": "يامجرب الايام انا مثلك وفي هذا الصدد",
              "ajz": "يا ما بذلنا فيه من جهدٍ يعدينا الحدود"
            },
            {
              "sadr": "ناطا على روس الافاعي والشكاعي والكدد",
              "ajz": "والله ولا قرطوع بعد اسبوع من ديس الكدود"
            },
            {
              "sadr": "نطرح بدد نجمع بدد ما تجتمع كل البدد",
              "ajz": "خلا البدد تطلع بدد زايد بدد كم البدود"
            },
            {
              "sadr": "ومن لانفع وقت الرخا ما فاد في وقت الشدد",
              "ajz": "مايصبر الا كل رجالٍ على الشده شدود"
            },
            {
              "sadr": "ومن يزرع المعروف اخير امن اللذي يزرع فدد",
              "ajz": "ولا خير في اللي مع بني عمه عن الواجب صدود"
            },
            {
              "sadr": "والله يود الخير للي عنده لغيره ودد",
              "ajz": "والله يضد اللي مع المخطي على ربعه ضدود"
            },
            {
              "sadr": "والقاف تم اللي بنيت ابدايته على ادد",
              "ajz": "وانهايته وانهاية ابن ادم سوى والفظ دود"
            }
          ]
        }
      ]
    },
    {
      "id": "ext-4",
      "name": "فهد بن نعيم العازمي العتيبي",
      "poems": [
        {
          "id": "ext-4-poem-1",
          "title": "جتني بيوتك ياخو ترحاب عسّيف",
          "role": "رد",
          "source": "موقع الشعر",
          "mujarat": {
            "respondingToPoet": "ضيف الله بن سويلم",
            "respondingToTitle": "القاف الاول عاسفينه على سيف",
            "respondingToId": "poet-2-poem-5"
          },
          "verses": [
            {
              "sadr": "جتني بيوتك ياخو ترحاب عسّيف",
              "ajz": "مجوهراتٍ بالحلي صوّغنّي"
            },
            {
              "sadr": "منها نجوم الليل خجلى وكسّيف",
              "ajz": "مدللات وبالدلع نغنغني"
            },
            {
              "sadr": "يكتب لها التاريخ فالذاكره سيف",
              "ajz": "تسلب لبيب المستمع والمغني"
            },
            {
              "sadr": "من شاعرٍ غاص البحور النواسيف",
              "ajz": "وحروف قاموسه اعرابٍ بغني"
            },
            {
              "sadr": "له فالادب والشعر مافاق الارسيف",
              "ajz": "حاش المراجل عنه ما روغني"
            },
            {
              "sadr": "كريم سبلابالرخى والتكاسيف",
              "ajz": "واذكار جوده من صباه ابزغني"
            },
            {
              "sadr": "لعل شمسه ما تهرّف بتكسيف",
              "ajz": "ضيف الله اللي بالقصيده شغنّي"
            },
            {
              "sadr": "درب بيوت الشعر تدريب جوسيف",
              "ajz": "شد انتباهي والمسامع صغني"
            },
            {
              "sadr": "نعمين والله ويهبون المخاسيف",
              "ajz": "روسٍ تطول وروس لا يدمغني"
            },
            {
              "sadr": "يفداه سودان الوجيه المواسيف",
              "ajz": "اللي لحاهم بالردا صبغني"
            },
            {
              "sadr": "ناسٍ بترويج النمايم سراسيف",
              "ajz": "الهيم من حوض الوبا يملغني"
            },
            {
              "sadr": "ماني حليف منظمات الينوسيف",
              "ajz": "عنها منابيه الحواس ابلغني"
            },
            {
              "sadr": "ياجاهلٍ فالوقت ابا انصحك بيسيف",
              "ajz": "صبرك ولو ان الليالي بغني"
            }
          ]
        }
      ]
    },
    {
      "id": "ext-5",
      "name": "علي بن سالم العازمي",
      "poems": [
        {
          "id": "ext-5-poem-1",
          "title": "يامن تحت رحمتك صاحي ونايم",
          "role": "رد",
          "source": "موقع الشعر",
          "mujarat": {
            "respondingToPoet": "ضيف الله السويلم",
            "respondingToTitle": "يالله ياللي مابه الا انت دايم",
            "respondingToId": "poet-2-poem-9"
          },
          "verses": [
            {
              "sadr": "يامن تحت رحمتك صاحي ونايم",
              "ajz": "ياعالٍ فوق الخلايق تساما"
            },
            {
              "sadr": "ادعيك يامعبودراكع وقايم",
              "ajz": "تجعل كلامي من كلام القداما"
            },
            {
              "sadr": "لو كنت عن بعض المداخيل شايم",
              "ajz": "عند اللزوم آرد ووردي علىما"
            },
            {
              "sadr": "البارحه هبت بجاشي سمايم",
              "ajz": "منها معاليق الضمايرتواما"
            },
            {
              "sadr": "هموم ليلٍ زايمتني مزايم",
              "ajz": "لو لاي احاميها بصبري محاما"
            },
            {
              "sadr": "يابن سويلم لا تحررقسايم",
              "ajz": "لونسمع النمام ياما وياما"
            },
            {
              "sadr": "طبع المنافق مايحب التلايم",
              "ajz": "لويستطيع يحول بين التواما"
            },
            {
              "sadr": "ناسٍ ربت بالحقد وألها دعايم",
              "ajz": "قلوبهم من ما كساها تداما"
            },
            {
              "sadr": "على ضعوف الخلق سوو زعايم",
              "ajz": "كنك تفرج في مسلسل دراما"
            },
            {
              "sadr": "والمرجله لوهي بلبس العمايم",
              "ajz": "لقيت كل اهل العمايم نشاما"
            },
            {
              "sadr": "مير المراجل بيت ساس وقوايم",
              "ajz": "ويقدرعليها من يفك الزحاما"
            },
            {
              "sadr": "اللي بحب الطيب والجود هايم",
              "ajz": "ماهو عشير مرودعات الوشاما"
            },
            {
              "sadr": "وانت الذي في غبت العرف عايم",
              "ajz": "شاعرورجل امن وخطيب واماما"
            },
            {
              "sadr": "ماانته من اللي يقبلون الهزايم",
              "ajz": "مدام مشيك في حدود النظاما"
            },
            {
              "sadr": "قلته وانا مع كلمة الحق دايم",
              "ajz": "والحق زود ولاينقص مقاما"
            },
            {
              "sadr": "واناادري ان الجو ماهو ملايم",
              "ajz": "ان مالحقني من وراه اتهاما"
            },
            {
              "sadr": "ولياذكرت اهل الفعول القدايم",
              "ajz": "اللي بحزات الشدايد حزاما"
            },
            {
              "sadr": "قلت الف نعم بروسنا فالزخايم",
              "ajz": "واقف لبعض اسما السيوخ احتراما"
            },
            {
              "sadr": "ولاسب راع الطيب عير البهايم",
              "ajz": "اللي على عد الرخامه حياما"
            },
            {
              "sadr": "والك التحيه عد نوح الحمايم",
              "ajz": "ويبلغ سلامك والك مني سلاما"
            }
          ]
        }
      ]
    }
  ],
  "poets": [
    {
      "id": "poet-1",
      "name": "تراحيب السويلم",
      "wasm": "wasm-1",
      "bio": "تراحيب بن سويلم العتيبي، شاعر نبطي سعودي، ضابط متقاعد من الحرس الوطني بحايل.",
      "poems": [
        {
          "id": "poet-1-poem-1",
          "title": "برج خليفة",
          "role": "",
          "meter": "",
          "date": "2011",
          "source": "موقع الشعر",
          "verses": [
            {
              "sadr": "لو الشعوب إلى الثريا تسابق",
              "ajz": "ما أحدٍ سبق بالفعل شعب الأمارات"
            },
            {
              "sadr": "ودليلنا ميّة وستين طابق",
              "ajz": "اللي بنوها فوق كل العمارات"
            },
            {
              "sadr": "برجٍ بنوه، بطيب الأفعال عابق",
              "ajz": "من آجل الفخر ماهو من أجل الإيجارات"
            },
            {
              "sadr": "شعب وحكومه للمعالي سوابق",
              "ajz": "بنّو عماراتٍ وبنّو منارات"
            },
            {
              "sadr": "فوق السحاب أعمالهم سبق سابق",
              "ajz": "وقمّة خليفه فوق كل العبارات"
            }
          ]
        },
        {
          "id": "poet-1-poem-2",
          "title": "شكراً وهي كافيه",
          "role": "",
          "meter": "",
          "date": "2011",
          "source": "موقع الشعر",
          "verses": [
            {
              "sadr": "ياكاتب أبياتي وفيت",
              "ajz": "تسلم يمين وافيه"
            },
            {
              "sadr": "من غير ما أنخاك إنتخيت",
              "ajz": "ياكامل الآوصافيه"
            },
            {
              "sadr": "وكتبت لي تسعين بيت",
              "ajz": "مع مثلها بالقافيه"
            },
            {
              "sadr": "مشكور يالغالي وليت",
              "ajz": "دايم حياتك صافيه"
            },
            {
              "sadr": "عساك طيب ماحييت",
              "ajz": "ترفل بثوب العافيه"
            },
            {
              "sadr": "دامك على الواضح مشيت",
              "ajz": "مابه نوايا خافيه"
            },
            {
              "sadr": "أنا لماتكتب قريت",
              "ajz": "وشفت آجوبتكم شافيه"
            },
            {
              "sadr": "ماينهدم بني بنيت",
              "ajz": "وشكراً ولاهي كافيه"
            }
          ]
        },
        {
          "id": "poet-1-poem-3",
          "title": "ردّ على ابن شامان",
          "role": "رد",
          "meter": "",
          "date": "2008",
          "source": "موقع الشعر",
          "mujarat": {
            "respondingToPoet": "فلاح بن شامان الشمري",
            "respondingToTitle": "قصيدة ابن شامان",
            "respondingToId": ""
          },
          "verses": [
            {
              "sadr": "حي الكتاب اللي من الشمّري جيب",
              "ajz": "أقولها بالصدق ماني بكذاب"
            },
            {
              "sadr": "يا مرحبا عد النجوم المراقيب",
              "ajz": "ترحيب مشتاقٍ ليا شاف الأحباب"
            },
            {
              "sadr": "بكتاب ابن شامان رجل المواجيب",
              "ajz": "فيه الجواهر بين صايغ وحساب"
            },
            {
              "sadr": "بنيت له بأقصى ضميري دواليب",
