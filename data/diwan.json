            {
              "sadr": "ليا شاف وجه المسير جاه رجافه",
              "ajz": "وزودٍ على البخل لا ديّن ولا فتني"
            },
            {
              "sadr": "ان قلت عطنا طرايف ماضي اسلافه",
              "ajz": "قال ام الاولاد يمديها تباطتني"
            },
            {
              "sadr": "من خلقته قارنٍ رأسه بمعلافه",
              "ajz": "عند مهدومه قبل ما غاب لو حتني"
            },
            {
              "sadr": "ابعد ومالك ومال النذل وأحلافه",
