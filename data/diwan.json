          "id": "poet-1-poem-6",
          "title": "لاتغرك يافتى دنيا الورى",
          "role": "",
          "meter": "",
          "date": "2008",
          "source": "موقع الشعر",
          "verses": [
            {
              "sadr": "لاتغرك يافتى دنيا الورى",
              "ajz": "لوتدوم لحى مادامت سنين"
            },
            {
              "sadr": "قم بدينك وانذر الى ما درى",
              "ajz": "واعبد الله لين ياتيك اليقين"
            },
            {
              "sadr": "الهوى والنفس بالسؤ أو مرى",
              "ajz": "والأمل غدار وابليس اللعين"
            },
            {
              "sadr": "لو وصلت النجم ترجع للثرى",
              "ajz": "كل ماسويت بالدنيا يبين"
            },
            {
              "sadr": "ساعة فيها القبور اتبعثرى",
              "ajz": "وانت يا مغرور بأعمالك رهين"
            },
            {
              "sadr": "آه من عين سرى عنها الكرى",
              "ajz": "ما تنام العين والخافق حزين"
            },
            {
              "sadr": "من كريم نزله بام القرى",
              "ajz": "في بلد مكه على الرجل الأمين"
            },
            {
              "sadr": "يوم الجمع الخلق كله بالعرى",
              "ajz": "أطلبك تجعل كتابي باليمين"
            },
            {
              "sadr": "حطلي دون اللهب ظل وذرى",
              "ajz": "من لجى بحمالك بحصن حصين"
            }
          ]
        },
        {
          "id": "poet-1-poem-7",
          "title": "يا ولد من يوم عيوا بالاجازه",
          "role": "",
          "meter": "",
          "date": "2008",
          "source": "موقع الشعر",
          "verses": [
            {
              "sadr": "يا ولد من يوم عيوا بالاجازه",
              "ajz": "حضروا كشف الغياب وسجلوني"
            },
            {
              "sadr": "لي وليفٍ بين شقراء والمحازه",
              "ajz": "عهدنا به قبل تفريق الضعوني"
            },
            {
              "sadr": "طالبك يا سعود مسح لي قزازه",
              "ajz": "والأديتر غلقه من ماء عيوني"
            },
            {
              "sadr": "لو تعرض له وعر والا غرازه",
              "ajz": "ما رحمت الجمس والكاين يكوني"
            },
            {
              "sadr": "دون هاك الزين ما للجمس عازه",
              "ajz": "وان طفا من دون خلي نزلوني"
            },
            {
              "sadr": "واحفروا قبري وحطوا له ركازه",
              "ajz": "وأقرؤوا الدنيا سلامي وادفنوني"
            },
            {
              "sadr": "وادعوا المعبود يغفر للجنازه",
              "ajz": "يرحم الميت وللحيين عوني"
            }
          ]
        },
        {
          "id": "poet-1-poem-8",
          "title": "من بدة اللفات ما أقشرك لفه",
          "role": "",
          "meter": "",
          "date": "2008",
          "source": "موقع الشعر",
          "verses": [
            {
              "sadr": "من بدة اللفات ما أقشرك لفه",
              "ajz": "لاعاد لفه والدركسون به بوش"
            },
            {
              "sadr": "خطٍ غزير ولفةٍ مع مطفه",
              "ajz": "والفرمله باكم تحجر على النوش"
            },
            {
              "sadr": "في رملةٍ لو ينبطح من يدفه",
              "ajz": "والله لو حيله مثل حيل علوش"
            },
            {
              "sadr": "انه ليطلب صاج والواح صفه",
              "ajz": "والا يجيب ارجال وحبال وونوش"
            }
          ]
        },
