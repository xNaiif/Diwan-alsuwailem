              "ajz": "ينفّذ مراسيم الحكومه ويكرمها"
            },
            {
              "sadr": "لو أنه من أقصى الهند وألا سمر قندي",
              "ajz": "عذرت العجم في الجهل ماني بلايمها"
            },
            {
              "sadr": "لكنّه من أصل العرب وأصل العرب يندي",
              "ajz": "وغلط غلطة الدكتور وأخفى معالمها"
            },
            {
              "sadr": "قوانين دوليّه سعودي وهولندي",
              "ajz": "قوانين هيئآت الأُمم رح تعلمها"
