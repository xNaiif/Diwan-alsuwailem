            {
              "sadr": "بدو ماتعرف إلا المشاعيب والقندي",
              "ajz": "اليا حافها الشيطان طشّت عمايمها"
            }
          ]
        },
        {
          "id": "poet-2-poem-5",
          "title": "القاف الاول عاسفينه على سيف",
          "role": "بدع",
          "meter": "",
          "date": "2008",
          "source": "موقع الشعر",
          "verses": [
            {
              "sadr": "القاف الاول عاسفينه على سيف",
              "ajz": "والشطر الاخر موقفينه بغني"
            },
            {
              "sadr": "إن ما عسفت القاف جاله عواسيف",
              "ajz": "وان كان ما غنيت غيري يغني"
            },
            {
              "sadr": "كم من نجومٍ من تهامه اليا السيف",
              "ajz": "كواكبٍ على الكوكب طغني"
            },
            {
              "sadr": "انا على الطيب كثير التحاسيف",
              "ajz": "وشرد القوافي روحن ما بغني"
            },
            {
              "sadr": "حاولت أعدل ارقاب الاصعاب بالسيف",
              "ajz": "يا دوب لدن يمنا واصطغني"
            },
            {
              "sadr": "ترايعت مثل البكار المعاسيف",
              "ajz": "حرايرٍ عقب التعصوي رغني"
            },
            {
              "sadr": "وعقلتهن ماهي هروجٍ سفاسيف",
              "ajz": "دغدغتهن لين انهن دغدغني"
            },
            {
              "sadr": "تهدى لابو ريان من غير تأسيف",
              "ajz": "الشاعر اللي من مغنه مغني"
            },
            {
              "sadr": "رجلٍ يحط الحيل فوق المناسيف",
              "ajz": "وعنده دلال الهيل ما يفرغني"
            },
            {
              "sadr": "يشكي من اللي نسف الهرج تنسيف",
              "ajz": "عدة شكاويٍ للفهيم ابلغني"
            },
            {
              "sadr": "ياجاهلٍ فالوقت ابا انصحك بيسيف",
              "ajz": "صبرك ولو ان الليالي بغني"
            }
          ]
        },
        {
          "id": "poet-2-poem-6",
          "title": "الشعر فن ومن هل الفن قالوه",
          "role": "",
          "meter": "",
          "date": "2008",
          "source": "موقع الشعر",
          "verses": [
            {
              "sadr": "الشعر فن ومن هل الفن قالوه",
              "ajz": "ومن راد يحصيهم تبهذل تبهذال"
            },
            {
              "sadr": "إن جيت أصوغ القاف كم ناس صاغوه",
              "ajz": "ولو أذكر الأسماء ذكرت ابن هذال"
            },
            {
              "sadr": "والا ذكرنا دايم السيف وأخوه",
              "ajz": "والاّ السديري والزلامي وبذال"
            },
            {
              "sadr": "يا عاذلين القلب خلوه خلوه",
              "ajz": "قلب العنا ما يستمع قول عذال"
            },
            {
              "sadr": "ما يسمع العذال من غير مزلوه",
              "ajz": "ويرتاح لإن عدا طويلات الاقذال"
            },
            {
              "sadr": "في مرقبٍ رؤوس الرياجيل زاروه",
              "ajz": "ومخصوص للابطال من دون الانذال"
            },
            {
              "sadr": "الكذب والبهتان ودَوه ردَوه",
              "ajz": "وهذي صفه موجودةٍ عند الأرذال"
            },
            {
              "sadr": "يحكي بناسٍ بالمراجل تعدوه",
              "ajz": "وعن فعلهم قاصر وقف وقفة الذال"
            },
            {
              "sadr": "ما ينقص الطيب حكي كل معتوه",
              "ajz": "ولا تذرب الصفوه مناقيد الأوذال"
            },
            {
              "sadr": "يا سايقين الكيف مروا وعدوه",
              "ajz": "وخلوه يشعر بالمهونه والاخذال"
            },
            {
              "sadr": "وعلى هل المعروف والجود مدوه",
              "ajz": "أهل الثناء وأهل الشجاعه والإبذال"
            }
          ]
        },
        {
          "id": "poet-2-poem-7",
          "title": "سر يا قلم واكتب على بيض الورق",
          "role": "رد",
          "meter": "",
          "date": "2008",
          "source": "موقع الشعر",
          "mujarat": {
            "respondingToPoet": "حبيب بن دغيم العازمي",
            "respondingToTitle": "ضيف الله اخترت القوافي والطواريق الجدد",
            "respondingToId": "ext-3-poem-1"
          },
          "verses": [
            {
              "sadr": "سر يا قلم واكتب على بيض الورق",
              "ajz": "شعر الفصاحه والنبط مشمول بحروف المدود"
            },
            {
              "sadr": "للشاعر اللي مثل حد السيف ما يبغى حدد",
              "ajz": "هو عزوتي فالواجبات القاه كالسيف محدود"
            },
            {
              "sadr": "اللي يحد القاف حدٍ ما جرى مثله حدد",
              "ajz": "كبل قوافيه الجدد حتى اصبح القاف محدود"
            },
            {
              "sadr": "جدد كما بدوٍ من المرباع يبغون الجدد",
              "ajz": "يقطف ثمر ينقش حجر غاص البحر ماهو محدود"
            },
            {
              "sadr": "أرسل لي ابياتٍ كما الياقوت ما عنها صدد",
              "ajz": "مالي عذر هذا ولد عمي ليا عد العدود"
            },
            {
              "sadr": "عذب الكلام أحلى من البرحي على وقت الجدد",
              "ajz": "ليا جابه الراقي من النخله بعد جده جدود"
            },
            {
              "sadr": "كم شاعرٍ شعره بقي مده ويتبعها مدد",
              "ajz": "وانته من اللي شعرهم يبقى على مر المدود"
            },
            {
              "sadr": "عسى عيونٍ تتبع الغرات يعميها السدد",
              "ajz": "وايضا عيون الحاسدين تسدها كل السدود"
            },
            {
              "sadr": "اصل الحصان اللي يفد يفوز من قوى الفدد",
              "ajz": "عند آخر المضمار بالميدان يشتد الفدود"
            },
            {
              "sadr": "والفارس المغوار مع شدت عنانه يشتدد",
              "ajz": "لو ما اشتدد يمكن يخالف سرجها لولا الشدود"
            },
            {
              "sadr": "من شأن نقطع دابر الارهاب أعددنا العدد",
              "ajz": "جميع ما يقضي على الفتنه مجهز ومعدود"
            },
            {
              "sadr": "بعض العرب عقب التقدم طاش فكره وارتدد",
              "ajz": "مثل اللذي جهز شداده للذلول بلا بدود"
            },
            {
              "sadr": "كم من عنيدٍ طاح والطيحه على وجهه مدد",
              "ajz": "وبعد سقط حظه سقط ما قام من بعد المدود"
            },
            {
              "sadr": "والانس مثل الجن في صح وخطأ كانوا قدد",
              "ajz": "كانوا طرائق صالحين ودون ذلك بالقدود"
            },
            {
              "sadr": "والذيب فالامثال ما يأكل يده مهما احتدد",
              "ajz": "والفار مهما كان ما يؤمن بتخريب السدود"
            },
            {
              "sadr": "والحر فالهجمه يخلي ريش صيداته بدد",
              "ajz": "والخرب الابرق ما يطير إن شاهد الحر مهدود"
            },
            {
              "sadr": "واللي يكد التكس ما يجمع رصيد من الكدد",
              "ajz": "لو جاب رد ورد ما يجمع رصيد من الردود"
            },
            {
              "sadr": "من لا يحوش المرجله ينقد جيب أمه قدد",
              "ajz": "وايضا خواته ومرته راحت ملابسهن قدود"
            },
            {
              "sadr": "ومن لا تقاضى حي ما فاده ليا مات السدد",
              "ajz": "مهما يكون من السدد ما ينفعه كثر السدود"
            },
            {
              "sadr": "الرد جاك اسرع من الارماش في لمحة لدد",
              "ajz": "عينٍ تلد النا نلد الها ونظرتنا لدود"
            }
          ]
        },
