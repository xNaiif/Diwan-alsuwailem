      "poems": [
        {
          "id": "poet-1-poem-1",
          "title": "برج خليفة",
          "role": "",
          "meter": "",
          "date": "2011",
          "source": "موقع الشعر",
          "verses": [
            {
              "sadr": "لو الشعوب إلى الثريا تسابق",
              "ajz": "ما أحدٍ سبق بالفعل شعب الأمارات"
            },
            {
              "sadr": "ودليلنا ميّة وستين طابق",
              "ajz": "اللي بنوها فوق كل العمارات"
            },
            {
              "sadr": "برجٍ بنوه، بطيب الأفعال عابق",
              "ajz": "من آجل الفخر ماهو من أجل الإيجارات"
            },
            {
              "sadr": "شعب وحكومه للمعالي سوابق",
              "ajz": "بنّو عماراتٍ وبنّو منارات"
            },
            {
              "sadr": "فوق السحاب أعمالهم سبق سابق",
              "ajz": "وقمّة خليفه فوق كل العبارات"
            }
          ]
        },
        {
          "id": "poet-1-poem-2",
          "title": "شكراً وهي كافيه",
          "role": "",
          "meter": "",
          "date": "2011",
          "source": "موقع الشعر",
          "verses": [
            {
              "sadr": "ياكاتب أبياتي وفيت",
              "ajz": "تسلم يمين وافيه"
            },
            {
              "sadr": "من غير ما أنخاك إنتخيت",
              "ajz": "ياكامل الآوصافيه"
            },
            {
              "sadr": "وكتبت لي تسعين بيت",
              "ajz": "مع مثلها بالقافيه"
            },
            {
              "sadr": "مشكور يالغالي وليت",
              "ajz": "دايم حياتك صافيه"
            },
            {
              "sadr": "عساك طيب ماحييت",
              "ajz": "ترفل بثوب العافيه"
            },
            {
              "sadr": "دامك على الواضح مشيت",
              "ajz": "مابه نوايا خافيه"
            },
            {
              "sadr": "أنا لماتكتب قريت",
              "ajz": "وشفت آجوبتكم شافيه"
            },
            {
              "sadr": "ماينهدم بني بنيت",
              "ajz": "وشكراً ولاهي كافيه"
            }
          ]
        },
        {
          "id": "poet-1-poem-3",
          "title": "ردّ على ابن شامان",
          "role": "رد",
          "meter": "",
          "date": "2008",
          "source": "موقع الشعر",
          "mujarat": {
            "respondingToPoet": "فلاح بن شامان الشمري",
            "respondingToTitle": "قصيدة ابن شامان",
            "respondingToId": ""
          },
          "verses": [
            {
              "sadr": "حي الكتاب اللي من الشمّري جيب",
              "ajz": "أقولها بالصدق ماني بكذاب"
            },
            {
              "sadr": "يا مرحبا عد النجوم المراقيب",
              "ajz": "ترحيب مشتاقٍ ليا شاف الأحباب"
            },
            {
              "sadr": "بكتاب ابن شامان رجل المواجيب",
              "ajz": "فيه الجواهر بين صايغ وحساب"
            },
            {
              "sadr": "بنيت له بأقصى ضميري دواليب",
              "ajz": "هذا الرصيد اللي كنزته وراء الباب"
            },
            {
              "sadr": "يا عل ما يفتق على مثله الجيب",
              "ajz": "والله يجيره من صواديف الأسباب"
            }
          ]
        },
        {
          "id": "poet-1-poem-4",
          "title": "عرضت لي وأنا عابر سبيل",
          "role": "",
          "meter": "",
          "date": "2008",
          "source": "موقع الشعر",
          "verses": [
            {
              "sadr": "عرضت لي وأنا عابر سبيل",
              "ajz": "والغريب إنّها من حارتي"
            },
            {
              "sadr": "النظر يم جاري مايخيل",
              "ajz": "ونظرتي ماتلد لجارتي"
            },
            {
              "sadr": "ما ألتفت للقصير وللطويل",
              "ajz": "لو بلمحه ورى نظارتي"
            },
            {
              "sadr": "لو دعتني ليا غاب الخليل",
              "ajz": "عزة النفس هي تجارتي"
            },
            {
              "sadr": "رحت عنها على وارد جميل",
              "ajz": "لو بكت ماتشوف زيارتي"
            },
            {
              "sadr": "واحمد الله شرابي سلسبيل",
              "ajz": "واعزف لحني على قيثارتي"
            }
          ]
        },
        {
          "id": "poet-1-poem-5",
          "title": "يامرحبا عد وبلٍ هل هملوله",
          "role": "رد",
          "meter": "",
          "date": "2008",
          "source": "موقع الشعر",
          "mujarat": {
            "respondingToPoet": "حبيب العازمي",
            "respondingToTitle": "قصيدة حبيب الأصلية",
            "respondingToId": "ext-1-poem-1"
          },
          "verses": [
            {
              "sadr": "يامرحبا عد وبلٍ هل هملوله",
              "ajz": "من مزنةٍ هلّت الماء من صنابرها"
            },
            {
              "sadr": "والف هلا بالبريد وحي مرسوله",
              "ajz": "اللي يجيب الرسايل من مصادرها"
            },
            {
              "sadr": "أبيات مثل الجواهر جات محموله",
              "ajz": "مجلة المختلف تحمل بشايرها"
            },
            {
              "sadr": "رسالةٍ من عيون الشعر معقوله",
              "ajz": "شكراً لمن قالها واشكر محررها"
            },
            {
              "sadr": "دايم سيوفه على الشعار مسلوله",
              "ajz": "وعند اللقا ينجلي عنها توترها"
            },
            {
              "sadr": "ازبن هل الحق واخذ الحق بدلوله",
              "ajz": "سوات زبنة رشيد ان كان تذكرها"
            },
            {
              "sadr": "ماضاع حقٍ وراه رجال مسؤوله",
              "ajz": "من خلقة الناس مسلمها وكافرها"
            },
            {
              "sadr": "بيوت الاجواد بالقانون مدخوله",
              "ajz": "وبيوت الانذال ودّك من يدمرها"
            }
          ]
        },
        {
          "id": "poet-1-poem-6",
          "title": "لاتغرك يافتى دنيا الورى",
          "role": "",
          "meter": "",
          "date": "2008",
          "source": "موقع الشعر",
          "verses": [
            {
              "sadr": "لاتغرك يافتى دنيا الورى",
              "ajz": "لوتدوم لحى مادامت سنين"
            },
            {
              "sadr": "قم بدينك وانذر الى ما درى",
              "ajz": "واعبد الله لين ياتيك اليقين"
            },
            {
              "sadr": "لو وصلت النجم ترجع للثرى",
              "ajz": "كل ماسويت بالدنيا يبين"
            },
            {
              "sadr": "يوم الجمع الخلق كله بالعرى",
              "ajz": "أطلبك تجعل كتابي باليمين"
            },
            {
              "sadr": "حطلي دون اللهب ظل وذرى",
              "ajz": "من لجى بحمالك بحصن حصين"
            }
          ]
        },
        {
          "id": "poet-1-poem-7",
          "title": "يا ولد من يوم عيوا بالاجازه",
          "role": "",
          "meter": "",
          "date": "2008",
          "source": "موقع الشعر",
          "verses": [
            {
              "sadr": "يا ولد من يوم عيوا بالاجازه",
              "ajz": "حضروا كشف الغياب وسجلوني"
            },
            {
              "sadr": "لي وليفٍ بين شقراء والمحازه",
              "ajz": "عهدنا به قبل تفريق الضعوني"
            },
            {
              "sadr": "طالبك يا سعود مسح لي قزازه",
              "ajz": "والأديتر غلقه من ماء عيوني"
            },
            {
              "sadr": "واحفروا قبري وحطوا له ركازه",
              "ajz": "وأقرؤوا الدنيا سلامي وادفنوني"
            },
            {
              "sadr": "وادعوا المعبود يغفر للجنازه",
              "ajz": "يرحم الميت وللحيين عوني"
            }
          ]
        },
        {
          "title": "يامرحبا عد وبل هل هملوله",
          "role": "رد",
          "meter": "",
          "date": "2010",
          "source": "موقع الشعر",
          "verses": [
            {
              "sadr": "يامرحبا عد وبل ٍ هل هملوله",
              "ajz": "من مزنة ٍ هلّت الماء من صنابرها"
            },
            {
              "sadr": "والف ٍ هلا بالبريد وحي مرسوله",
              "ajz": "اللي يجيب الرسايل من مصادرها"
            },
            {
              "sadr": "ابيات مثل الجواهر جات محموله",
              "ajz": "مجلة المختلف تحمل بشايرها"
            },
            {
              "sadr": "رسالة ٍ من عيون الشعر معقوله",
              "ajz": "شكرا ً لمن قالها واشكر محررها"
            },
            {
              "sadr": "من شاعر ٍ فالمحافل يكسب الجوله",
              "ajz": "في كل ميدان مايخشى مخاطرها"
            },
            {
              "sadr": "دايم سيوفه على الشعار مسلوله",
              "ajz": "وعند اللقا ينجلي عنها توترها"
            },
            {
              "sadr": "من عاصفة قوة التصفيق من حوله",
              "ajz": "ترجف صفوف الملاعب في تناحرها"
            },
            {
              "sadr": "والصف والكف والتصفيق من قوله",
              "ajz": "يعيش نادر حرار ٍ من مواكرها"
            },
            {
              "sadr": "له قصة ٍ ثابته ماهيب منقوله",
              "ajz": "عندي خبر كل ماضيها وحاضرها"
            },
            {
              "sadr": "السر بين الكفيل وبين مكفوله",
              "ajz": "الحر يفهم وانا ماني بناشرها"
            },
            {
              "sadr": "مابين مر الزمان وحلو معسوله",
              "ajz": "ماهمها غير وصلك وانت هاجرها"
            },
            {
              "sadr": "عهديبها ياحبيب شبه مشلوله",
              "ajz": "باقي عليها بقايا من جواهرها"
            },
            {
              "sadr": "مذعورة ٍ من زمان ٍ منه مذهوله",
              "ajz": "تنخى حبيب تشبث به باظافرها"
            },
            {
              "sadr": "متحجبه في وقار ٍ تلبس سموله",
              "ajz": "وجد ّك حبيب شهد ذورة تبخترها"
            },
            {
              "sadr": "بشهود برقا وتشهد روق بفعوله",
              "ajz": "اهل الشهامات ماتهفي ظمايرها"
            },
            {
              "sadr": "تشهد مطير وقبايل حرب شهدوله",
              "ajz": "انشد وعيره وتشهد لك وعايرها"
            },
            {
              "sadr": "ازبن هل الحق واخذ الحق بدلوله",
              "ajz": "سوات زبنة رشيد ان كان تذكرها"
            },
            {
              "sadr": "ماضاع حق ٍ وراه رجال مسؤوله",
              "ajz": "من خلقة الناس مسلمها وكافرها"
            },
            {
              "sadr": "خل المعاذير لا ماهيب مقبوله",
              "ajz": "لو المخاليق تشهر لك خناجرها"
            },
            {
              "sadr": "بيوت الاجواد بالقانون مدخوله",
              "ajz": "وبيوت الانذال ود ّك من يدمرها"
            }
