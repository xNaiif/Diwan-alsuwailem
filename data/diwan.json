              "sadr": "ولنا مع كفاح البطل عبد العزيز شهود",
              "ajz": "ولنا موقفٍ كل المخاليق تدريبه"
            },
            {
              "sadr": "تحت راية التوحيد قادة وصف جنود",
              "ajz": "ولنا فإنتصار الحق فعلٍ نماريبه"
            },
            {
              "sadr": "وحكمها الإمام وصار حكم العدل موجود",
              "ajz": "وأزال الفتن والظلم قفّت مناديبه"
            },
            {
              "sadr": "واتموا نظام العود بعده عيال العود",
              "ajz": "وساروا على نهجه وحكمه وأساليبه"
            },
            {
              "sadr": "عسى الله يديم أمن الوطن في ذرى آل سعود",
              "ajz": "وصلوا على اللي ساكنٍ في ثرى طيبة"
            }
          ]
        },
        {
