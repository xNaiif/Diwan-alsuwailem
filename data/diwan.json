        {
          "id": "ext-2-poem-1",
          "title": "حبيب العازمي- ردو سلامي لبو ناصر",
          "role": "بدع",
          "source": "موقع الشعر",
          "verses": [
            {
              "sadr": "ردوا سلامي لابوناصر وقولو له",
              "ajz": "يقرا الرساله من اولها ليا آخرها"
            },
            {
              "sadr": "ارسالة ٍ مع وجيه الخير مرسوله",
              "ajz": "والمسك والعود الازرق في مكاسرها"
            },
            {
              "sadr": "وجّهتها من ضمير ٍ ضايق ٍ جوله",
              "ajz": "للشاعر اللي معانيها يقد ّرها"
            },
            {
              "sadr": "شاعر ويفتل وينقض كل مفتوله",
              "ajz": "وإرسالتي ماحد ٍ غيره يفسرها"
            },
            {
              "sadr": "ان كان ماحلها ماهيب محلوله",
              "ajz": "ابا اكتم السر لين الله ييسّرها"
            },
            {
              "sadr": "لي قصة ٍ واضحه في حكم مجهوله",
              "ajz": "قصة غرام ٍ تعبّر عن مشاعرها"
            },
            {
              "sadr": "من شانها القلب والافكار مشغوله",
              "ajz": "والنار وسط الحشا شبّت سعايرها"
            },
            {
              "sadr": "كنّي بعزله وكن الناس معزوله",
              "ajz": "واستغرب الناس ماكني بخابرها"
            },
            {
              "sadr": "واصول لو كان لاصوله ولاجوله",
              "ajz": "احاول احل دعوايه وادبرها"
            },
            {
              "sadr": "واصاحبي دونه البيبان مقفوله",
              "ajz": "ماياصله كود من يقدر يكسرها"
            },
            {
              "sadr": "العام حوله وحول العام جا حوله",
              "ajz": "وانا عنه سجتي بالرجل قاصرها"
            },
            {
              "sadr": "ماهوب ودي لكن السلم وأوصوله",
              "ajz": "يردني والعرب كثرت مشاورها"
            },
            {
              "sadr": "خلي ورا دولة ٍ من دونها دوله",
              "ajz": "دوله ودوله مجهّزة ٍ عساكرها"
            },
            {
              "sadr": "حتى خطوط الهواتف عنه مفصوله",
              "ajz": "نقطة قلم وسط غبّه من يدورها"
            },
            {
              "sadr": "حاولت لين ان جهدي ضاع مفعوله",
              "ajz": "غيّر عرب والطبيعه ماتغيرها"
            },
            {
              "sadr": "والحبل لو يستوي عرضه على طوله",
              "ajz": "كل ّ ٍ يطّول حباله مايقصرها"
            },
            {
              "sadr": "ودروب ماتندهل ودروب مدهوله",
              "ajz": "ولا كل من يعبر الاقطار يعبرها"
            },
            {
              "sadr": "هذه موجز وكثر الهرج وشهو له",
              "ajz": "الله يعلم بباطنها وظاهرها"
            },
            {
              "sadr": "يعلم على كل ماننويه ونقوله",
              "ajz": "وفي حكمه النفس ينهاها ويامرها"
            },
            {
              "sadr": "واختامها عد نو ّ ٍ هلّت ثعوله",
              "ajz": "بالمسك والورد والكادي نعطّرها"
            }
          ]
        }
      ]
    }
  ],
